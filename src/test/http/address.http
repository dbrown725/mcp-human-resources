@baseUrl = http://localhost:8081

### Get address by ID (existing)
GET {{baseUrl}}/addresses/10002

> {%
client.test("Get existing address returns 200", function() {
  client.assert(response.status === 200, "Expected status 200, got " + response.status);
});
%}

### Get remote address by ID (existing)
GET {{baseUrl}}/addresses/10000

> {%
client.test("Get existing remote address returns 200", function() {
  client.assert(response.status === 200, "Expected status 200, got " + response.status);
});
%}

### Get address by ID (not found scenario)
GET {{baseUrl}}/addresses/999999

> {%
client.test("Get missing address returns 404", function() {
  client.assert(response.status === 404, "Expected status 404, got " + response.status);
});
%}

### Search addresses by city/state/isRemote
GET {{baseUrl}}/addresses?city=Atlanta&state=GA&isRemote=false

> {%
client.test("Search by city/state/isRemote returns 200", function() {
  client.assert(response.status === 200, "Expected status 200, got " + response.status);
});
%}


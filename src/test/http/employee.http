### E2E step 1: create address for a new employee link
# @name createE2eAddress
POST {{baseUrl}}/addresses
Content-Type: application/json

{
  "streetAddress": "700 Midtown Way Apt 22",
  "city": "Atlanta",
  "state": "GA",
  "postalCode": "30308",
  "isRemote": false
}

> {%
client.test("E2E create address returns 200", function() {
  client.assert(response.status === 200, "Expected status 200, got " + response.status);
});
%}

### E2E step 2: create employee linked to addressId from step 1 response
# @name createE2eEmployee
POST {{baseUrl}}/employees
Content-Type: application/json

{
  "firstName": "E2E",
  "lastName": "AddressLink",
  "title": "QA Engineer",
  "department": "Engineering",
  "businessUnit": "Corporate",
  "gender": "Female",
  "ethnicity": "Asian",
  "age": 31,
  "hireDate": "2024-01-15",
  "annualSalary": 105000,
  "managerId": 5615,
  "addressId": {{createE2eAddress.response.body.$.addressId}}
}

> {%
client.test("E2E create employee returns 200", function() {
  client.assert(response.status === 200, "Expected status 200, got " + response.status);
});
%}

### E2E step 3: fetch employee and verify addressId is present
GET {{baseUrl}}/employees/{{createE2eEmployee.response.body.$.employeeId}}

> {%
client.test("E2E fetch employee returns 200", function() {
  client.assert(response.status === 200, "Expected status 200, got " + response.status);
});
%}

### E2E step 4: patch employee to remote address
PATCH {{baseUrl}}/employees/{{createE2eEmployee.response.body.$.employeeId}}
Content-Type: application/json

{
  "addressId": 10300,
  "title": "QA Engineer II"
}

> {%
client.test("E2E patch employee returns 200", function() {
  client.assert(response.status === 200, "Expected status 200, got " + response.status);
});
%}

### E2E step 5: verify employee after patch
GET {{baseUrl}}/employees/{{createE2eEmployee.response.body.$.employeeId}}

> {%
client.test("E2E verify employee after patch returns 200", function() {
  client.assert(response.status === 200, "Expected status 200, got " + response.status);
});
%}


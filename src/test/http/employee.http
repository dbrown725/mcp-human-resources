### Create employee (minimal)
POST {{baseUrl}}/employees
Content-Type: application/json

{
  "firstName": "Minimal",
  "lastName": "Employee"
}

> {%
client.test("Create minimal employee returns 200", function() {
  client.assert(response.status === 200, "Expected status 200, got " + response.status);
});
%}

### Create employee (full onsite profile)
# @name createEmployeeFull
POST {{baseUrl}}/employees
Content-Type: application/json

{
  "firstName": "John",
  "lastName": "Doe",
  "title": "Engineer",
  "department": "Engineering",
  "businessUnit": "Corporate",
  "gender": "Male",
  "ethnicity": "Caucasian",
  "age": 34,
  "hireDate": "2023-06-01",
  "annualSalary": 95000,
  "managerId": 5615,
  "addressId": 10010
}

> {%
client.test("Create full onsite employee returns 200", function() {
  client.assert(response.status === 200, "Expected status 200, got " + response.status);
});
%}

### Create employee (terminated / remote profile)
# @name createEmployeeForDelete
POST {{baseUrl}}/employees
Content-Type: application/json

{
  "firstName": "Jane",
  "lastName": "Smith",
  "title": "Engineer",
  "department": "Engineering",
  "businessUnit": "Corporate",
  "gender": "Female",
  "ethnicity": "Caucasian",
  "age": 34,
  "hireDate": "2020-05-10",
  "terminationDate": "2024-11-15",
  "annualSalary": 98000,
  "managerId": 5684,
  "addressId": 10300
}

> {%
client.test("Create terminated remote employee returns 200", function() {
  client.assert(response.status === 200, "Expected status 200, got " + response.status);
});
%}

### Patch employee by ID (partial update)
PATCH {{baseUrl}}/employees/{{createEmployeeFull.response.body.$.employeeId}}
Content-Type: application/json

{
  "title": "Senior Engineer",
  "department": "Engineering",
  "annualSalary": 123000,
  "addressId": 10020
}

> {%
client.test("Patch employee partial update returns 200", function() {
  client.assert(response.status === 200, "Expected status 200, got " + response.status);
});
%}

### Patch employee by ID (manager and demographic fields)
PATCH {{baseUrl}}/employees/{{createEmployeeFull.response.body.$.employeeId}}

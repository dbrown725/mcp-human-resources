@baseUrl = http://localhost:8081

### Get employee by ID (existing)
GET {{baseUrl}}/employees/5012

> {%
client.test("Get existing employee returns 200", function() {
  client.assert(response.status === 200, "Expected status 200, got " + response.status);
});
%}

### Get employee by ID (not found scenario)
GET {{baseUrl}}/employees/999999

> {%
client.test("Get missing employee returns 404", function() {
  client.assert(response.status === 404, "Expected status 404, got " + response.status);
});
%}


@baseUrl = http://localhost:8081

### Get employee by ID
GET {{baseUrl}}/employees/5012

### Save new employee
POST {{baseUrl}}/employees
Content-Type: application/json

{
  "firstName": "John",
  "lastName": "Doe",
  "email": "john.doe@megacorp.com",
  "department": "Engineering",
  "salary": 75000.00
}

### Delete employee by ID
DELETE {{baseUrl}}/employees/5012

### Save terminated employee (terminationDate set)
POST {{baseUrl}}/employees
Content-Type: application/json

{
  "firstName": "Jane",
  "lastName": "Smith",
  "title": "Engineer",
  "department": "Engineering",
  "businessUnit": "Corporate",
  "gender": "Female",
  "ethnicity": "Caucasian",
  "age": 34,
  "hireDate": "2020-05-10",
  "terminationDate": "2024-11-15",
  "annualSalary": 98000
}
